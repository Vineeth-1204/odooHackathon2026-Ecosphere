  description      String?
  carbonFootprint  Float
  waterFootprint   Float?
  wasteGenerated   Float?
  recyclability    Float?
  materialSourcing String?
  esgGrade         String
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@map("product_profiles")
}
