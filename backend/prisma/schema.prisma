model EmissionFactor {
  id                 String              @id @default(uuid())
  name               String              @unique
  value              Float
  unit               String
  categoryId         String
  category           Category            @relation(fields: [categoryId], references: [id])
  source             String?
  year               Int
  carbonTransactions CarbonTransaction[]
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt

  @@map("emission_factors")
}

model CarbonTransaction {
  id               String         @id @default(uuid())
  date             DateTime
  description      String
  activityValue    Float
  emissionFactorId String
  emissionFactor   EmissionFactor @relation(fields: [emissionFactorId], references: [id], onDelete: Cascade)
  emissions        Float
  departmentId     String
  department       Department     @relation(fields: [departmentId], references: [id], onDelete: Cascade)
  userId           String
  user             User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt

  @@map("carbon_transactions")
}

model EnvironmentalGoal {
  id           String      @id @default(uuid())
  name         String
  description  String?
  targetValue  Float
  currentValue Float       @default(0)
  unit         String
  startDate    DateTime
  endDate      DateTime
  status       String      @default("ACTIVE")
  departmentId String?
  department   Department? @relation(fields: [departmentId], references: [id], onDelete: SetNull)
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt

  @@map("environmental_goals")
}

